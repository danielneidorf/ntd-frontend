---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import QuickScanFlow from '../components/QuickScanFlow';
---

<BaseLayout title="NT Duomenys – QuickScan">
  <Header />

  <div class="max-w-[1200px] mx-auto px-6 py-8">

    <nav class="flex items-center gap-3 text-sm mb-10">
      <span class="font-semibold text-[#1E3A5F]">1 Vieta</span>
      <span class="text-[#64748B]">→</span>
      <span class="text-[#64748B]">2 Patvirtinimas</span>
      <span class="text-[#64748B]">→</span>
      <span class="text-[#64748B]">3 Užsakymas ir apmokėjimas</span>
    </nav>

    <main>
      <QuickScanFlow client:load />
    </main>

  </div>
</BaseLayout>

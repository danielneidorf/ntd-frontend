---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import QuickScanFlow from '../components/QuickScanFlow';
import Sources from '../components/Sources.astro';
import AIGuide from '../components/guide/AIGuide';
---

<BaseLayout title="NT Duomenys – QuickScan">
  <Header />

  <div class="max-w-[1200px] mx-auto px-4 md:px-8 py-8">

    <main>
      <QuickScanFlow client:load />
    </main>

  </div>
  <Sources />
  <AIGuide client:load tourId="quickscan" autoStart={true} />
</BaseLayout>

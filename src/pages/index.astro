---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import SituationCards from '../components/SituationCards.astro';
import MiniMockupGrid from '../components/MiniMockupGrid.astro';
import ComparisonTable from '../components/ComparisonTable.astro';
import AddressLookup from '../components/AddressLookup.astro';
import Pricing from '../components/Pricing.astro';
import Sources from '../components/Sources.astro';
import Footer from '../components/Footer.astro';
import AIGuide from '../components/guide/AIGuide';
---
<BaseLayout title="NT Duomenys — Nekilnojamojo turto duomenys">
  <Header />
  <main>
    <Hero />
    <MiniMockupGrid />
    <SituationCards />
    <ComparisonTable />
    <AddressLookup />

    <!-- Step 1.5: Resolver loading -->
    <div id="resolver-loading" class="hidden border-t border-[#E2E8F0] py-24">
      <div class="max-w-7xl mx-auto px-4 md:px-8 flex flex-col items-center gap-6">
        <div class="w-10 h-10 border-2 border-[#0D7377] border-t-transparent rounded-full animate-spin"></div>
        <div class="text-[15px] text-[#1E3A5F] font-medium">Tikriname registrus...</div>
        <div class="text-[13px] text-[#64748B]">NTR · PENS · Registrų centras · Kadastras</div>
      </div>
    </div>

    <!-- Screen 2: Confirm property -->
    <div id="screen-2" class="hidden border-t border-[#E2E8F0] py-16">
      <div class="max-w-[1200px] mx-auto px-4 md:px-16">
        <div class="text-[11px] font-semibold tracking-[0.12em] uppercase text-[#0D7377] mb-2">02 · Patvirtinkite objektą</div>
        <h2 class="text-[24px] font-semibold text-[#1E3A5F] mb-8">Ar tai teisingas objektas?</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">

          <!-- Proof card -->
          <div class="bg-white border border-[#E2E8F0] rounded-sm p-6">
            <div class="text-[11px] font-semibold tracking-[0.1em] uppercase text-[#64748B] mb-4">Rastas objektas</div>
            <div class="text-[16px] font-semibold text-[#1E3A5F] mb-1">Žirmūnų g. 12-45</div>
            <div class="text-[14px] text-[#64748B] mb-4">Vilnius, Šiaurės g. raj.</div>
            <div class="space-y-2 text-[13px] text-[#64748B]">
              <div class="flex justify-between"><span>NTR numeris</span><span class="text-[#1E3A5F] font-medium">1234-5678-9012</span></div>
              <div class="flex justify-between"><span>Paskirtis</span><span class="text-[#1E3A5F] font-medium">Gyvenamoji</span></div>
              <div class="flex justify-between"><span>Plotas</span><span class="text-[#1E3A5F] font-medium">68 m²</span></div>
              <div class="flex justify-between"><span>Statybos metai</span><span class="text-[#1E3A5F] font-medium">1978</span></div>
            </div>
            <div class="mt-6 flex gap-3">
              <button class="flex-1 py-2.5 bg-[#1E3A5F] text-white text-[13px] font-medium rounded-sm hover:bg-[#162d4a] transition-colors" id="confirm-object">
                Taip, tai teisingas objektas
              </button>
            </div>
            <button class="mt-3 w-full py-2.5 border border-[#E2E8F0] text-[#64748B] text-[13px] rounded-sm hover:border-[#1E3A5F] transition-colors">
              Ne, ieškoti kito
            </button>
          </div>

          <!-- EPC card -->
          <div class="bg-[#FAFBFC] border border-[#E2E8F0] rounded-sm p-6">
            <div class="text-[11px] font-semibold tracking-[0.1em] uppercase text-[#64748B] mb-1">Pasirinktinai</div>
            <div class="text-[15px] font-semibold text-[#1E3A5F] mb-1">Energijos naudingumo duomenys</div>
            <p class="text-[12px] text-[#64748B] mb-5 leading-[1.6]">
              Jei turite energijos naudingumo sertifikatą ar žinote faktines energijos sąnaudas,
              galite juos pateikti — tai padės tiksliau įvertinti objektą.
            </p>
            <div class="space-y-5">

              <!-- Upload EPC certificate -->
              <div>
                <label class="block text-[11px] font-semibold tracking-[0.1em] uppercase text-[#1E3A5F] mb-1.5">
                  Energinio naudingumo sertifikatas (PDF)
                </label>
                <div class="border-2 border-dashed border-[#E2E8F0] rounded-sm p-4 text-center cursor-pointer hover:border-[#0D7377] transition-colors">
                  <div class="text-[13px] text-[#64748B]">📄 Įkelti sertifikatą</div>
                  <div class="text-[11px] text-[#94A3B8] mt-1">PDF · sistema automatiškai nuskaitys duomenis</div>
                </div>
              </div>

              <div class="border-t border-[#E2E8F0] pt-5">
                <!-- kWh from bills/meters -->
                <label class="block text-[11px] font-semibold tracking-[0.1em] uppercase text-[#1E3A5F] mb-1.5">
                  Faktinės energijos sąnaudos (iš sąskaitų / skaitiklių)
                </label>
                <div class="flex gap-3 items-center mb-3">
                  <input type="number" placeholder="pvz. 145"
                    class="w-32 px-3 py-2.5 border border-[#E2E8F0] rounded-sm text-[13px] text-[#1E3A5F] focus:outline-none focus:border-[#0D7377]" />
                  <span class="text-[13px] text-[#64748B]">kWh/m² per metus</span>
                </div>
                <!-- Scope selector -->
                <div class="flex gap-3">
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="kwh-scope" value="heating" class="accent-[#0D7377]" checked />
                    <span class="text-[12px] text-[#64748B]">Tik šildymas</span>
                  </label>
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="kwh-scope" value="all" class="accent-[#0D7377]" />
                    <span class="text-[12px] text-[#64748B]">Visas komfortas (šildymas + vėsinimas + kt.)</span>
                  </label>
                </div>
              </div>

            </div>
          </div>

        </div>
      </div>
    </div>

    <!-- Screen 3: Quote + payment -->
    <div id="screen-3" class="hidden border-t border-[#E2E8F0] py-16">
      <div class="max-w-[1200px] mx-auto px-4 md:px-16">
        <div class="text-[11px] font-semibold tracking-[0.12em] uppercase text-[#0D7377] mb-2">03 · Užsakymas ir apmokėjimas</div>
        <h2 class="text-[24px] font-semibold text-[#1E3A5F] mb-8">Jūsų užsakymas</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">

          <!-- Left: quote summary -->
          <div class="space-y-6">
            <div class="bg-white border border-[#E2E8F0] rounded-sm p-6">
              <div class="text-[11px] font-semibold tracking-[0.1em] uppercase text-[#64748B] mb-4">Kaina</div>
              <div class="flex items-baseline gap-2 mb-1">
                <span class="text-[48px] font-semibold text-[#1E3A5F] leading-none">79 €</span>
                <span class="text-[13px] text-[#64748B]">vienkartinis mokėjimas</span>
              </div>
              <div class="text-[12px] text-[#0D7377] mb-5">Beta kaina. Galutinė kaina — 99 €.</div>
              <div class="border-t border-[#E2E8F0] pt-4 space-y-2 text-[13px] text-[#64748B]">
                <div class="flex justify-between"><span>Objektas</span><span class="text-[#1E3A5F] font-medium">Žirmūnų g. 12-45, Vilnius</span></div>
                <div class="flex justify-between"><span>Blokas</span><span class="text-[#1E3A5F] font-medium">1 — Šiluminis komfortas</span></div>
                <div class="flex justify-between"><span>Pristatymas</span><span class="text-[#1E3A5F] font-medium">PDF el. paštu per 24 val.</span></div>
              </div>
            </div>

            <!-- Kodėl tokia kaina -->
            <div class="bg-[#FAFBFC] border border-[#E2E8F0] rounded-sm p-6">
              <div class="text-[13px] font-semibold text-[#1E3A5F] mb-3">Kodėl tokia kaina?</div>
              <p class="text-[12px] text-[#64748B] leading-[1.7]">
                Kaina apima duomenų surinkimą iš keturių oficialių registrų, šiluminio komforto modelio skaičiavimus ir aiškios ataskaitos parengimą. Mokate tik vieną kartą — be prenumeratų ar papildomų mokesčių.
              </p>
            </div>
          </div>

          <!-- Right: email + consent + payment -->
          <div class="bg-white border border-[#E2E8F0] rounded-sm p-6 space-y-5">
            <div>
              <label class="block text-[11px] font-semibold tracking-[0.1em] uppercase text-[#1E3A5F] mb-1.5">El. paštas</label>
              <input type="email" placeholder="vardas@pastas.lt"
                class="w-full px-4 py-3 border border-[#E2E8F0] rounded-sm text-[14px] text-[#1E3A5F] placeholder-[#94A3B8] focus:outline-none focus:border-[#0D7377]" />
              <p class="mt-1.5 text-[11px] text-[#94A3B8]">Ataskaitą išsiųsime šiuo adresu.</p>
            </div>

            <div class="space-y-3">
              <label class="flex items-start gap-3 cursor-pointer">
                <input type="checkbox" class="mt-0.5 accent-[#0D7377]" />
                <span class="text-[12px] text-[#64748B] leading-[1.6]">
                  Sutinku su <a href="#" class="text-[#0D7377] underline">paslaugos teikimo sąlygomis</a> ir <a href="#" class="text-[#0D7377] underline">privatumo politika</a>.
                </span>
              </label>
              <label class="flex items-start gap-3 cursor-pointer">
                <input type="checkbox" class="mt-0.5 accent-[#0D7377]" />
                <span class="text-[12px] text-[#64748B]">Reikalinga sąskaita faktūra.</span>
              </label>
            </div>

            <button class="w-full py-4 bg-[#1E3A5F] text-white text-[15px] font-semibold rounded-sm hover:bg-[#162d4a] transition-colors" id="pay-button">
              Mokėti 79 € ir gauti ataskaitą
            </button>
            <p class="text-[11px] text-[#94A3B8] text-center leading-[1.6]">
              Mokėjimą tvarko Stripe. Kortelės duomenys NTD sistemoje nesaugomi.
            </p>
          </div>

        </div>
      </div>
    </div>

    <!-- Success screen -->
    <div id="screen-success" class="hidden border-t border-[#E2E8F0] py-24">
      <div class="max-w-[1200px] mx-auto px-4 md:px-16 flex flex-col items-center text-center gap-4">
        <div class="text-[40px]">✅</div>
        <h2 class="text-[24px] font-semibold text-[#1E3A5F]">Patvirtinome jūsų užsakymą.</h2>
        <p class="text-[15px] text-[#64748B] max-w-lg leading-[1.7]">
          Pradedame informacijos paiešką registruose, duomenų tikrinimą ir visų blokų skaičiavimus. Ataskaitą el. paštu paprastai išsiunčiame greitai, bet gali užtrukti iki 1 valandos.
        </p>
      </div>
    </div>

    <Pricing />
    <Sources showPropertyTypes={true} />
  </main>
  <Footer />
  <AIGuide client:load tourId="landing" />
</BaseLayout>

<script>
  function fadeIn(el) {
    el.classList.remove('hidden');
    el.style.opacity = '0';
    el.style.transition = 'opacity 0.6s ease';
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        el.style.opacity = '1';
      });
    });
    setTimeout(() => {
      const rect = el.getBoundingClientRect();
      const elementCenter = rect.top + window.scrollY + rect.height / 2;
      const viewportCenter = window.innerHeight / 2;
      window.scrollTo({ top: elementCenter - viewportCenter, behavior: 'smooth' });
    }, 50);
  }

  document.getElementById('lookup-submit')?.addEventListener('click', () => {
    document.getElementById('address-lookup')?.classList.add('hidden');
    const loading = document.getElementById('resolver-loading');
    if (loading) {
      fadeIn(loading);
      setTimeout(() => {
        loading.classList.add('hidden');
        const s2 = document.getElementById('screen-2');
        if (s2) fadeIn(s2);
      }, 2500);
    }
  });

  document.getElementById('confirm-object')?.addEventListener('click', () => {
    document.getElementById('screen-2')?.classList.add('hidden');
    const s3 = document.getElementById('screen-3');
    if (s3) fadeIn(s3);
  });

  document.getElementById('pay-button')?.addEventListener('click', () => {
    document.getElementById('screen-3')?.classList.add('hidden');
    document.getElementById('pricing-section')?.classList.add('hidden');
    const success = document.getElementById('screen-success');
    if (success) fadeIn(success);
  });

  const epcYearUnknown = document.getElementById('epc-year-unknown');
  const epcYearWarning = document.getElementById('epc-year-warning');
  const epcYear = document.getElementById('epc-year');
  epcYearUnknown?.addEventListener('change', () => {
    if (epcYearUnknown.checked) {
      if (epcYear) { epcYear.disabled = true; epcYear.value = ''; }
      epcYearWarning?.classList.remove('hidden');
    } else {
      if (epcYear) epcYear.disabled = false;
      epcYearWarning?.classList.add('hidden');
    }
  });
</script>
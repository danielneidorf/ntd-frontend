<section class="bg-[#F0F4F8] py-12">
  <div class="stats-strip max-w-[1200px] mx-auto px-8">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-0">

      <div class="flex flex-col items-center text-center lg:border-r lg:border-[#E2E8F0]">
        <span class="text-[28px] font-semibold text-[#1E3A5F]">6</span>
        <span class="text-[14px] text-[#64748B]">oficialių registrų šaltinių</span>
      </div>

      <div class="flex flex-col items-center text-center lg:border-r lg:border-[#E2E8F0]">
        <span class="text-[28px] font-semibold text-[#1E3A5F]">8</span>
        <span class="text-[14px] text-[#64748B]">duomenų blokai ataskaitoje</span>
      </div>

      <div class="flex flex-col items-center text-center lg:border-r lg:border-[#E2E8F0]">
        <span class="text-[28px] font-semibold text-[#1E3A5F]">&lt;24 val.</span>
        <span class="text-[14px] text-[#64748B]">pristatymas el. paštu</span>
      </div>

      <div class="flex flex-col items-center text-center">
        <span class="text-[28px] font-semibold text-[#1E3A5F]">0,1 %</span>
        <span class="text-[14px] text-[#64748B]">pirkinio vertės</span>
      </div>

    </div>
  </div>
</section>

<style>
  .stats-strip {
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.5s ease-out, transform 0.5s ease-out;
  }
  .stats-strip.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const strip = document.querySelector('.stats-strip');
  if (strip) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          strip.classList.add('visible');
          observer.disconnect();
        }
      },
      { threshold: 0.2 }
    );
    observer.observe(strip);
  }
</script>

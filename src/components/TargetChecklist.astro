<style>
  .target-checklist {
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.4s ease-out, transform 0.4s ease-out;
  }
  .target-checklist.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .target-checklist.visible .checklist-item {
    animation: fadeSlideIn 0.4s ease-out both;
  }
  .target-checklist.visible .checklist-item:nth-child(1) { animation-delay: 0s; }
  .target-checklist.visible .checklist-item:nth-child(2) { animation-delay: 0.06s; }
  .target-checklist.visible .checklist-item:nth-child(3) { animation-delay: 0.12s; }
  .target-checklist.visible .checklist-item:nth-child(4) { animation-delay: 0.18s; }
  .target-checklist.visible .checklist-item:nth-child(5) { animation-delay: 0.24s; }
  .target-checklist.visible .checklist-item:nth-child(6) { animation-delay: 0.30s; }
  .target-checklist.visible .checklist-item:nth-child(7) { animation-delay: 0.36s; }
  .target-checklist.visible .checklist-item:nth-child(8) { animation-delay: 0.42s; }

  @keyframes fadeSlideIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  const checklist = document.querySelector('.target-checklist');
  if (checklist) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          checklist.classList.add('visible');
          observer.disconnect();
        }
      },
      { threshold: 0.2 }
    );
    observer.observe(checklist);
  }
</script>

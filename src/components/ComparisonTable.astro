          <div>
            <span class="text-[12px] uppercase tracking-[0.05em] text-[#64748B]">ŠALTINIAI</span>
            <div class="text-[16px] text-[#1A1A2E]">Portalai, EPC PDF</div>
          </div>
          <div>
            <span class="text-[12px] uppercase tracking-[0.05em] text-[#64748B]">REZULTATAS</span>
            <div class="text-[16px] text-[#1A1A2E]">Fragmentiški duomenys</div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .comparison-cards {
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.5s ease-out, transform 0.5s ease-out;
  }
  .comparison-cards.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const cards = document.querySelector('.comparison-cards');
  if (cards) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          cards.classList.add('visible');
          observer.disconnect();
        }
      },
      { threshold: 0.2 }
    );
    observer.observe(cards);
  }
</script>

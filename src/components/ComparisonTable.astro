            <div class="text-[16px] text-[#1A1A2E]">250–700 €</div>
          </div>
          <div>
            <span class="text-[12px] uppercase tracking-[0.05em] text-[#64748B]">TRUKMĖ</span>
            <div class="text-[16px] text-[#1A1A2E]">3–5 darbo dienos</div>
          </div>
          <div>
            <span class="text-[12px] uppercase tracking-[0.05em] text-[#64748B]">VIZITAS</span>
            <div class="text-[16px] text-[#1A1A2E]">Būtinas</div>
          </div>
          <div>
            <span class="text-[12px] uppercase tracking-[0.05em] text-[#64748B]">ŠALTINIAI</span>
            <div class="text-[16px] text-[#1A1A2E]">Ekspertinis vertinimas</div>
          </div>
          <div>

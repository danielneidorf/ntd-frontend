---
<footer class="bg-white">
  <div class="max-w-[1200px] mx-auto px-16 pt-8 pb-[96px]">

    <div class="grid grid-cols-3 gap-16 mb-6">

      <!-- Brand -->
      <div>
        <a href="/" class="block text-[#1E3A5F] text-[18px] font-semibold tracking-tight mb-1 no-underline">NT Duomenys</a>
        <div class="text-[13px] text-[#94A3B8] mb-3">ntd.lt</div>
        <p class="text-[13px] text-[#64748B] leading-[1.7]">
          Nekilnojamojo turto duomenys iš oficialių Lietuvos registrų, duomenų bazių.
        </p>
      </div>

      <!-- Informacija -->
      <div>
        <div class="text-[11px] font-semibold tracking-[0.12em] uppercase text-[#94A3B8] mb-2">Informacija</div>
        <ul class="space-y-1.5">
          <li><a href="#" class="text-[14px] text-[#64748B] hover:text-[#1E3A5F] transition-colors">Apie NTD</a></li>
          <li><a href="#" class="text-[14px] text-[#64748B] hover:text-[#1E3A5F] transition-colors">Privatumo politika</a></li>
          <li><a href="#" class="text-[14px] text-[#64748B] hover:text-[#1E3A5F] transition-colors">Naudojimo sąlygos</a></li>
        </ul>
      </div>

      <!-- Kontaktai -->
      <div>
        <div class="text-[11px] font-semibold tracking-[0.12em] uppercase text-[#94A3B8] mb-2">Kontaktai</div>
        <ul class="space-y-1.5">
          <li><a href="mailto:info@ntd.lt" class="text-[14px] text-[#64748B] hover:text-[#1E3A5F] transition-colors">info@ntd.lt</a></li>
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="border-t border-[#E2E8F0] pt-4 flex items-center justify-between">
      <p class="text-[12px] text-[#94A3B8]">
        © 2026 NT Duomenys. Duomenys iš oficialių Lietuvos registrų.
      </p>
      <p class="text-[12px] text-[#94A3B8]">
        LT · EN
      </p>
    </div>

  </div>
</footer>
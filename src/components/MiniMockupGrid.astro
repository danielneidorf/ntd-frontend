<style>
  .mockup-grid {
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.4s ease-out, transform 0.4s ease-out;
  }
  .mockup-grid.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .mockup-grid.visible .mockup-card {
    animation: fadeSlideIn 0.4s ease-out both;
  }
  .mockup-grid.visible .mockup-card:nth-child(1) { animation-delay: 0s; }
  .mockup-grid.visible .mockup-card:nth-child(2) { animation-delay: 0.05s; }
  .mockup-grid.visible .mockup-card:nth-child(3) { animation-delay: 0.1s; }
  .mockup-grid.visible .mockup-card:nth-child(4) { animation-delay: 0.15s; }
  .mockup-grid.visible .mockup-card:nth-child(5) { animation-delay: 0.2s; }
  .mockup-grid.visible .mockup-card:nth-child(6) { animation-delay: 0.25s; }
  .mockup-grid.visible .mockup-card:nth-child(7) { animation-delay: 0.3s; }
  .mockup-grid.visible .mockup-card:nth-child(8) { animation-delay: 0.35s; }

  @keyframes fadeSlideIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  const grid = document.querySelector('.mockup-grid');
  if (grid) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          grid.classList.add('visible');
          observer.disconnect();
        }
      },
      { threshold: 0.2 }
    );
    observer.observe(grid);
  }
</script>

---
import ReportCarousel from './ReportCarousel.astro';
---
<section id="pricing-section" class="py-16" style="scroll-margin-top: calc(50vh - 330px);">
  <div class="max-w-[1200px] mx-auto px-16">

    <div class="grid grid-cols-2 gap-24 items-center">

      <!-- Left: Pricing card -->
      <div class="bg-white border border-[#E2E8F0] rounded-sm p-12">
        <div class="text-[11px] font-semibold tracking-[0.15em] uppercase text-[#0D7377] mb-6">
          Kaina nuo
        </div>
        <div class="flex items-baseline gap-2 mb-10">
          <span class="text-[56px] font-semibold text-[#1E3A5F] leading-none">39 €</span>
          <span class="text-[16px] text-[#64748B]">/ objektas</span>
        </div>

        <div class="space-y-3">
          <div class="flex items-center gap-3">
            <div class="w-4 h-4 rounded-full bg-[#059669] flex items-center justify-center flex-shrink-0">
              <svg width="8" height="6" viewBox="0 0 8 6" fill="none"><path d="M1 3L3 5L7 1" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <span class="text-[14px] text-[#1A1A2E]">Vienkartinis mokėjimas, jokių prenumeratų</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-4 h-4 rounded-full bg-[#059669] flex items-center justify-center flex-shrink-0">
              <svg width="8" height="6" viewBox="0 0 8 6" fill="none"><path d="M1 3L3 5L7 1" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <span class="text-[14px] text-[#1A1A2E]">PDF dokumentas el. paštu per 1 val.</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-4 h-4 rounded-full bg-[#059669] flex items-center justify-center flex-shrink-0">
              <svg width="8" height="6" viewBox="0 0 8 6" fill="none"><path d="M1 3L3 5L7 1" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <span class="text-[14px] text-[#1A1A2E]">Duomenys iš oficialių duomenų bazių ir jais paremti skaičiavimai</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-4 h-4 rounded-full bg-[#059669] flex items-center justify-center flex-shrink-0">
              <svg width="8" height="6" viewBox="0 0 8 6" fill="none"><path d="M1 3L3 5L7 1" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <span class="text-[14px] text-[#1A1A2E]">Jokių nepagrįstų prielaidų</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-4 h-4 rounded-full bg-[#059669] flex items-center justify-center flex-shrink-0">
              <svg width="8" height="6" viewBox="0 0 8 6" fill="none"><path d="M1 3L3 5L7 1" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <span class="text-[14px] text-[#1A1A2E]">Mokėjimas tik jums patvirtinus objektą</span>
          </div>
        </div>

        <a href="/quickscan/" class="block w-full text-center bg-[#1E3A5F] text-white text-[14px] font-medium py-3 rounded-lg hover:bg-[#0D7377] transition-colors mt-8">
          Užsakyti ataskaitą
        </a>
      </div>

      <!-- Right: Report blocks carousel (what you get for 79€) -->
      <div class="flex items-center justify-end">
        <ReportCarousel />
      </div>

    </div>
  </div>
</section>